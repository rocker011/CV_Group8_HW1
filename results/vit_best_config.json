{
  "image_size": 28,
  "patch_size": 7,
  "embed_dim": 160,
  "num_heads": 4,
  "depth": 6,
  "mlp_ratio": 2.0,
  "activation": "gelu",
  "normalization": "batchnorm",
  "pooling": "cls",
  "dropout": 0.1,
  "embedding_dropout": 0.1,
  "attention_dropout": 0.0,
  "head_dropout": 0.1,
  "num_classes": 47,
  "optimizer": "adamw",
  "learning_rate": 0.0003,
  "scheduler": "ReduceLROnPlateau",
  "scheduler_params": {
    "t_max": 8,
    "eta_min": 1e-05,
    "mode": "min",
    "factor": 0.5,
    "patience": 1
  },
  "weight_decay": 0.0,
  "l1_lambda": 0.0,
  "epochs": 8,
  "early_stopping_patience": 3
}